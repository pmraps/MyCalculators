<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Flags>
        <SaveClosedFiles Value="False"/>
        <SaveOnlyProjectUnits Value="True"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="mycalculators"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <LazDoc Paths="documentation" PackageName="pmradocsmycalc"/>
    <i18n>
      <EnableI18N Value="True"/>
      <OutDir Value="languages"/>
    </i18n>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <AutoIncrementBuild Value="True"/>
      <BuildNr Value="243"/>
      <Language Value="0816"/>
      <Attributes pvaDebug="True"/>
      <StringTable CompanyName="HBCB"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="DateTimeCtrlsDsgn"/>
      </Item>
      <Item>
        <PackageName Value="eccontrols"/>
      </Item>
      <Item>
        <PackageName Value="DateTimeCtrls"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="mycalculators.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="maincalculators.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="frmMyCalculators"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="mainCalculators"/>
      </Unit>
      <Unit>
        <Filename Value="help.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="frmHelp"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="Help"/>
      </Unit>
      <Unit>
        <Filename Value="myresourcestrings.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="myResourceStrings"/>
      </Unit>
      <Unit>
        <Filename Value="mycredits.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="frmCredits"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="MyCredits"/>
      </Unit>
      <Unit>
        <Filename Value="preferences.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="frmPreferences"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="Preferences"/>
      </Unit>
      <Unit>
        <Filename Value="errorcatching.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="ErrorCatching"/>
      </Unit>
      <Unit>
        <Filename Value="mydatefunctions.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="mycalculators"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
